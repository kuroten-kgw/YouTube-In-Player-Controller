{
  "manifest_version": 3,
  "name": "YouTube In-Player Controller",
  "version": "2.0",
  "description": "YouTubeの再生画面内に、シークと速度調整の専用UIを追加します。",
  "permissions": [],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}