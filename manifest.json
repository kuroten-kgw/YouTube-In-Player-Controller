{
  "manifest_version": 3,
  "name": "YouTube In-Player Controller",
  "version": "1.1",
  "description": "YouTubeとニコニコ動画の再生画面内に、専用コントローラーを追加します。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.nicovideo.jp/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.nicovideo.jp/*"
      ],
      "js": ["content.js"]
    }
  ]
}